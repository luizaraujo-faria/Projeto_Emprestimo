@model Projeto_Emprestimo.Models.Livro

@{
    ViewData["Title"] = "CodLivro";
}

<h2 style="text-align:center;">Novo Livro</h2>

<div class="center">
    @using (Html.BeginForm("Index","Livros", FormMethod.Post, new { ecntype = "multipart/form-data" })){

    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="form-group space-around-flex">
            <div class="">
                @Html.LabelFor(model => model.nomeLivro, htmlAttributes: new { @class = "control-label col-md-2" })
            </div>
            <div class="col-md-10">
                @Html.EditorFor(model => model.nomeLivro, new { htmlAttributes = new { @class = "form-control" } })
                @Html.ValidationMessageFor(Model => Model.nomeLivro, "", new { @class = "text-danger" })
            </div>
        </div>
        <div class="form-group center">
            <div>
                <label class="control-label col-md-2" for="file" />Capa Livro</label>
            </div>
            <div class="col-md-10">
                <input type="file" name="file" id="file" /> <br />
            </div>
        </div>
        <div class="form-group center">
            <div class="col-md-10">
                @ViewBag.mgs <br />
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Salvar Produto" class="btn btn-success" />
            </div>
        </div>
    </div>
    }
</div>




